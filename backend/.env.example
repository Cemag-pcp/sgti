# Django backend environment

# WhatsApp provider: BOT (local bot API) or WAHA
WHATSAPP_PROVIDER=BOT

# BOT local API URL (for provider BOT)
WHATSAPP_API_URL=http://localhost:3333

# Optional for WAHA provider
WHATSAPP_API_KEY=
WHATSAPP_SESSION=default

# Token validated by backend webhook header X-Webhook-Token
WHATSAPP_WEBHOOK_SECRET=

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODEL=
GEMINI_TIMEOUT_SECONDS=15
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_SECONDS=1.5
WHATSAPP_CONVERSATION_TIMEOUT_MINUTES=30
